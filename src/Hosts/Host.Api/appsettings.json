{
  "ApplicationIdentity": {
    "DisplayName": "GMA Skeleton",
    "Namespace": "gma"
  },
  "Persistence": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "PostgreSql": "",
    "nats": ""
  },
  "Caching": {
    "Enabled": false,
    "Provider": "Memory",
    "DefaultDistributedExpiration": "00:05:00",
    "DefaultLocalExpiration": "00:00:30",
    "MaximumPayloadBytes": 1048576,
    "MaximumKeyLength": 1024,
    "Redis": {
      "ConnectionName": "redis"
    }
  },
  "Tenancy": {
    "Enabled": true,
    "HeaderName": "X-Tenant-Id",
    "LocalDefaultTenantId": "default"
  },
  "Outbox": {
    "BatchSize": 25,
    "PollIntervalMilliseconds": 5000,
    "LockDurationMilliseconds": 60000,
    "MaxAttempts": 10
  },
  "MessageJournalCleanup": {
    "Enabled": false,
    "CleanupProcessedOutbox": true,
    "CleanupProcessedInbox": true,
    "ProcessedOutboxRetention": "7.00:00:00",
    "ProcessedInboxRetention": "14.00:00:00",
    "BrokerReplayHorizon": "7.00:00:00",
    "CleanupInterval": "01:00:00",
    "BatchSize": 500,
    "MaxBatchesPerStorePerCycle": 10
  },
  "NatsJetStream": {
    "Enabled": false,
    "ManagementMode": "Managed",
    "Storage": "File",
    "MaxAge": "7.00:00:00",
    "MaxBytes": 1073741824,
    "MaxMessages": 10000000,
    "Replicas": 1,
    "DuplicateWindow": "00:02:00"
  },
  "NatsConsumers": {
    "Enabled": false,
    "FetchBatchSize": 10,
    "PollInterval": "00:00:01",
    "AckWait": "00:00:30",
    "AckProgressInterval": "00:00:10",
    "MaxDeliver": 5,
    "HandlerTimeout": "00:00:30",
    "NakDelay": "00:00:01"
  },
  "Notifications": {
    "Enabled": false,
    "SubscriberQueueCapacity": 128,
    "MaximumPayloadBytes": 32768,
    "Sse": {
      "Enabled": true,
      "StreamPath": "/api/notifications/stream",
      "NotificationEventType": "notification",
      "HeartbeatInterval": "00:00:15"
    },
    "SignalR": {
      "Enabled": true,
      "HubPath": "/hubs/notifications",
      "ClientMethodName": "notification",
      "AccessTokenQueryParameter": "access_token"
    },
    "DurableStreams": {
      "BatchSize": 25,
      "PollInterval": "00:00:01"
    },
    "Delivery": {
      "Enabled": true,
      "BatchSize": 50,
      "MaxConcurrency": 8,
      "PollIntervalSeconds": 5,
      "LeaseSeconds": 60,
      "MaxAttempts": 8,
      "RetryBaseSeconds": 5,
      "RetryMaxMinutes": 30,
      "AttemptRetentionDays": 90
    },
    "Retention": {
      "Enabled": false,
      "ReadHistoryDays": 90,
      "UnreadHistoryDays": 365,
      "BroadcastDays": 365,
      "BatchSize": 500,
      "MaxBatchesPerCategoryPerCycle": 4,
      "IntervalMinutes": 60
    },
    "Adapters": {
      "Email": {
        "Enabled": false,
        "ProviderName": "email",
        "SenderAddress": null,
        "SenderName": null,
        "SubjectPrefix": null
      }
    }
  },
  "Observability": {
    "Prometheus": {
      "Enabled": false,
      "EndpointPath": "/metrics"
    },
    "Otlp": {
      "Enabled": false,
      "Endpoint": null,
      "ExportMetrics": true,
      "ExportTraces": true,
      "ExportLogs": true
    }
  },
  "Http": {
    "AllowAnyHost": false,
    "HttpsRedirectionEnabled": true,
    "HstsEnabled": true,
    "SecurityHeadersEnabled": true,
    "ForwardedHeaders": {
      "Enabled": false,
      "AllowUnknownProxies": false,
      "ForwardLimit": 1,
      "KnownProxies": []
    },
    "Cors": {
      "Enabled": false,
      "AllowCredentials": false,
      "AllowedOrigins": []
    },
    "RequestTimeouts": {
      "Enabled": true,
      "DefaultTimeoutSeconds": 30
    },
    "RateLimiting": {
      "Enabled": true,
      "GlobalPermitLimit": 300,
      "SensitivePermitLimit": 10,
      "WindowSeconds": 60,
      "SensitivePathPrefixes": [ "/api/auth/register", "/api/auth/login", "/api/auth/refresh", "/api/auth/browser", "/api/auth/password", "/api/auth/external", "/api/auth/email-verification" ]
    }
  },
  "Auth": {
    "RefreshTokenLifetimeDays": 30,
    "ExternalExchangeLifetimeMinutes": 5,
    "ExternalLinkSessionFreshnessMinutes": 10,
    "EmailVerificationLifetimeMinutes": 1440,
    "EmailVerificationRequestCooldownSeconds": 60,
    "Retention": {
      "Enabled": false,
      "ExpiredExchangeHistoryHours": 24,
      "SessionHistoryDays": 365,
      "BatchSize": 500,
      "MaxBatchesPerCategoryPerCycle": 4,
      "IntervalMinutes": 60
    },
    "RefreshTokens": {
      "Pepper": ""
    },
    "Jwt": {
      "SigningKey": "",
      "AccessTokenLifetimeMinutes": 15
    },
    "OpenIdConnect": {
      "Enabled": false,
      "AllowedReturnUrls": [],
      "Providers": {
        "google": {
          "Enabled": false,
          "Authority": "https://accounts.google.com",
          "ClientId": "",
          "ClientSecret": "",
          "Scopes": [ "openid", "email", "profile" ],
          "EmailClaim": "email",
          "EmailVerifiedClaim": "email_verified",
          "TreatEmailAsVerified": false
        },
        "microsoft": {
          "Enabled": false,
          "Authority": "https://login.microsoftonline.com/common/v2.0",
          "ClientId": "",
          "ClientSecret": "",
          "Scopes": [ "openid", "email", "profile" ],
          "EmailClaim": "email",
          "EmailVerifiedClaim": "email_verified",
          "TreatEmailAsVerified": false
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "localhost;127.0.0.1"
}
