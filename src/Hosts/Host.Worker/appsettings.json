{
  "ApplicationIdentity": {
    "DisplayName": "GMA Skeleton Worker",
    "Namespace": "gma"
  },
  "Persistence": {
    "Provider": "SqlServer"
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "PostgreSql": "",
    "nats": ""
  },
  "Worker": {
    "Modules": {
      "Auth": false,
      "Notifications": false,
      "Organizations": false,
      "Catalog": false,
      "Ordering": false,
      "TaskRuntime": false,
      "TaskSamples": false
    }
  },
  "Organizations": {
    "Retention": {
      "Enabled": false,
      "InvitationHistoryDays": 90,
      "EnrollmentHistoryDays": 90,
      "BatchSize": 500,
      "MaxBatchesPerCategoryPerCycle": 4,
      "IntervalMinutes": 60
    }
  },
  "Caching": {
    "Enabled": false,
    "Provider": "Memory",
    "DefaultDistributedExpiration": "00:05:00",
    "DefaultLocalExpiration": "00:00:30",
    "MaximumPayloadBytes": 1048576,
    "MaximumKeyLength": 1024,
    "Redis": {
      "ConnectionName": "redis"
    }
  },
  "Tenancy": {
    "Enabled": true,
    "HeaderName": "X-Tenant-Id",
    "LocalDefaultTenantId": "default"
  },
  "Outbox": {
    "BatchSize": 25,
    "PollIntervalMilliseconds": 5000,
    "LockDurationMilliseconds": 60000,
    "MaxAttempts": 10
  },
  "MessageJournalCleanup": {
    "Enabled": false,
    "CleanupProcessedOutbox": true,
    "CleanupProcessedInbox": true,
    "ProcessedOutboxRetention": "7.00:00:00",
    "ProcessedInboxRetention": "14.00:00:00",
    "BrokerReplayHorizon": "7.00:00:00",
    "CleanupInterval": "01:00:00",
    "BatchSize": 500,
    "MaxBatchesPerStorePerCycle": 10
  },
  "NatsJetStream": {
    "Enabled": false,
    "ManagementMode": "Managed",
    "Storage": "File",
    "MaxAge": "7.00:00:00",
    "MaxBytes": 1073741824,
    "MaxMessages": 10000000,
    "Replicas": 1,
    "DuplicateWindow": "00:02:00"
  },
  "NatsConsumers": {
    "Enabled": false,
    "FetchBatchSize": 10,
    "PollInterval": "00:00:01",
    "AckWait": "00:00:30",
    "AckProgressInterval": "00:00:10",
    "MaxDeliver": 5,
    "HandlerTimeout": "00:00:30",
    "NakDelay": "00:00:01"
  },
  "Tasks": {
    "Worker": {
      "Enabled": false,
      "WorkerGroups": [ "default" ],
      "BatchSize": 10,
      "MaxConcurrency": 1,
      "PollInterval": "00:00:01",
      "LeaseDuration": "00:00:30",
      "HeartbeatInterval": "00:00:10",
      "HandlerTimeout": "00:00:30",
      "RetryBaseDelay": "00:00:02",
      "RetryMaxDelay": "00:05:00",
      "TimeoutScannerEnabled": true,
      "TimeoutScannerPollInterval": "00:00:30",
      "StaleHeartbeatTimeout": "00:05:00",
      "TimeoutScannerBatchSize": 100,
      "MetricsSamplerEnabled": true,
      "MetricsSamplerPollInterval": "00:00:15"
    }
  },
  "TaskRuntimeRetention": {
    "Enabled": false,
    "SucceededRunRetention": "30.00:00:00",
    "FailedRunRetention": "90.00:00:00",
    "CanceledRunRetention": "30.00:00:00",
    "TimedOutRunRetention": "90.00:00:00",
    "HandledControlRetention": "30.00:00:00",
    "FailedControlRetention": "90.00:00:00",
    "ExpiredControlRetention": "30.00:00:00",
    "CleanupInterval": "01:00:00",
    "BatchSize": 500,
    "MaxBatchesPerStatusPerCycle": 10
  },
  "Auth": {
    "Retention": {
      "Enabled": false,
      "ExpiredExchangeHistoryHours": 24,
      "SessionHistoryDays": 365,
      "BatchSize": 500,
      "MaxBatchesPerCategoryPerCycle": 4,
      "IntervalMinutes": 60
    }
  },
  "Notifications": {
    "DurableStreams": {
      "BatchSize": 25,
      "PollInterval": "00:00:01"
    },
    "Delivery": {
      "Enabled": true,
      "BatchSize": 50,
      "MaxConcurrency": 8,
      "PollIntervalSeconds": 5,
      "LeaseSeconds": 60,
      "MaxAttempts": 8,
      "RetryBaseSeconds": 5,
      "RetryMaxMinutes": 30,
      "AttemptRetentionDays": 90
    },
    "Retention": {
      "Enabled": false,
      "ReadHistoryDays": 90,
      "UnreadHistoryDays": 365,
      "BroadcastDays": 365,
      "BatchSize": 500,
      "MaxBatchesPerCategoryPerCycle": 4,
      "IntervalMinutes": 60
    },
    "Adapters": {
      "Email": {
        "Enabled": false,
        "ProviderName": "email",
        "SenderAddress": null,
        "SenderName": null,
        "SubjectPrefix": null
      }
    }
  },
  "Observability": {
    "Prometheus": {
      "Enabled": false,
      "EndpointPath": "/metrics"
    },
    "Otlp": {
      "Enabled": false,
      "Endpoint": null,
      "ExportMetrics": true,
      "ExportTraces": true,
      "ExportLogs": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
